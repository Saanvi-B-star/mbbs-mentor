# ==============================================
# MBBS Mentor Backend - Environment Variables
# ==============================================

# --------------------------------------------
# REQUIRED - Application Configuration
# --------------------------------------------

# Application Environment (development | production | test)
NODE_ENV=development

# Server Port
PORT=5000

# CORS Origins (comma-separated URLs)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# --------------------------------------------
# REQUIRED - Database Configuration
# --------------------------------------------

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/mbbs_mentor
DATABASE_URL=postgresql://postgres:password@localhost:5432/mbbs_mentor

# --------------------------------------------
# REQUIRED - JWT Configuration
# --------------------------------------------

# JWT Secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-please-change-this

# JWT Access Token Expiration (e.g., 15m, 1h, 1d)
JWT_EXPIRES_IN=15m

# JWT Refresh Token Secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters-long-please-change-this

# JWT Refresh Token Expiration (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------
# REQUIRED - AI Configuration (OpenRouter)
# --------------------------------------------

# OpenRouter API Key
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter Base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter Default Model
OPENROUTER_DEFAULT_MODEL=openai/gpt-3.5-turbo

# ============================================
# OPTIONAL SERVICES
# Leave blank or comment out if not using
# ============================================

# --------------------------------------------
# OPTIONAL - Redis (Required for background jobs)
# --------------------------------------------

# Redis URL
# Format: redis://[username:password@]host:port
# Example: redis://localhost:6379
# Leave commented out to disable background job processing
# REDIS_URL=redis://localhost:6379

# --------------------------------------------
# OPTIONAL - AWS Services
# --------------------------------------------
# Required for: File uploads (S3), Email (SES), OCR (Textract)
# If not configured, these features will be disabled

# AWS Region
# AWS_REGION=us-east-1

# AWS Credentials
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# AWS S3 Configuration
# AWS_S3_BUCKET_NAME=mbbs-mentor-uploads
# AWS_S3_BUCKET_REGION=us-east-1

# AWS SES Configuration (Email)
# AWS_SES_REGION=us-east-1
# AWS_SES_FROM_EMAIL=noreply@yourdomain.com
# AWS_SES_FROM_NAME=MBBS Mentor

# AWS Textract Configuration (OCR)
# AWS_TEXTRACT_REGION=us-east-1

# --------------------------------------------
# OPTIONAL - Razorpay (Payment Gateway)
# --------------------------------------------
# Required for: Subscription payments
# If not configured, payment features will be disabled

# Razorpay Credentials
# Get from: https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --------------------------------------------
# OPTIONAL - OAuth Providers
# --------------------------------------------

# Google OAuth (Optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (Optional)
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_CLIENT_SECRET=your-apple-client-secret

# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. Copy this file to .env:
#    cp .env.example .env

# 2. Fill in the REQUIRED variables:
#    - DATABASE_URL: Set up PostgreSQL database
#    - JWT_SECRET & JWT_REFRESH_SECRET: Generate secure keys
#    - OPENROUTER_API_KEY: Get from OpenRouter

# 3. Optional: Configure optional services as needed
#    - Redis: For background jobs and caching
#    - AWS: For file uploads, email, and OCR
#    - Razorpay: For payment processing
#    - OAuth: For social login

# 4. Run database migrations:
#    npm run prisma:migrate

# 5. Start the development server:
#    npm run dev

# ============================================
# QUICK START (Minimal Setup)
# ============================================

# For initial testing, you only need:
# 1. DATABASE_URL (PostgreSQL)
# 2. JWT_SECRET & JWT_REFRESH_SECRET
# 3. OPENROUTER_API_KEY

# The app will run with these minimal settings.
# Optional services will show warnings but won't prevent startup.
